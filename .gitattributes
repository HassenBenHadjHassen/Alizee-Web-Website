# Normalisation des fins de ligne
* text=auto

# HTML, CSS, JS, PHP → LF
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.php text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf

# Fichiers binaires → pas de conversion
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
